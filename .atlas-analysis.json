  "keyFeatures": [
    "Automatic instrumentation for 100+ Node.js libraries and frameworks",
    "Manual instrumentation API with tracer.trace() and tracer.wrap()",
    "OpenTelemetry and OpenTracing compatibility",
    "Application Security (AppSec) with IAST and RASP",
    "Continuous Profiler for CPU, memory, and wall-time profiling",
    "LLM Observability SDK for AI/ML monitoring",
    "CI Visibility for test reporting and flaky test detection",
    "Dynamic Instrumentation (debugger) for live debugging",
    "Data Streams Monitoring for pipeline observability",
    "Runtime metrics and DogStatsD integration"
  ],
  "publicApiSurface": [
    "tracer.init(options)",
    "tracer.trace(name, options, fn)",
    "tracer.wrap(name, options, fn)",
    "tracer.startSpan(name, options)",
    "tracer.inject(spanContext, format, carrier)",
    "tracer.extract(format, carrier)",
    "tracer.scope()",
    "tracer.use(plugin, config)",
    "tracer.setUser(user)",
    "tracer.setUrl(url)",
    "tracer.getRumData()",
    "tracer.appsec",
    "tracer.llmobs",
    "tracer.dogstatsd",
    "tracer.dataStreamsCheckpointer",
    "tracer.TracerProvider",
    "scope.active()",
    "scope.activate(span, fn)",
    "scope.bind(target, span)"
  ]
